[Unit]
Description=FastAPI Clothing Store
After=network.target

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/clothing-store/github-project/backend
Environment="PATH=/home/ec2-user/clothing-store/github-project/backend/venv/bin"
ExecStart=/home/ec2-user/clothing-store/github-project/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
